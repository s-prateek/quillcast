# ── AWS ───────────────────────────────────────────────────────────────────────
# Your AWS account ID and preferred region
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1

# ── Quillcast (populated after cdk deploy) ────────────────────────────────────
# Shown in CloudFormation Outputs after deploying StorageStack
QUILLCAST_CONFIG_BUCKET=quillcast-config-<account-id>-<region>

# ── LinkedIn OAuth (populated by scripts/linkedin_oauth.py) ──────────────────
# Register your app at https://developer.linkedin.com/
# Required scopes: openid, profile, w_member_social
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# ── Author profile (used in Streamlit LinkedIn preview only, never posted) ────
AUTHOR_NAME=Your Name
AUTHOR_HEADLINE=Your Headline
AUTHOR_PROFILE_PIC_URL=
