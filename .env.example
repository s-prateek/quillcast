# ── LLM (draft generation) ────────────────────────────────────────────────────
# Provider: claude (default) or gemini
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# LLM_MODEL=claude-3-5-haiku-latest

# ── Paths (optional overrides) ────────────────────────────────────────────────
# QUILLCAST_CONFIG_DIR=config
# QUILLCAST_DRAFTS_DIR=data/drafts

# ── LinkedIn OAuth (populated by scripts/linkedin_oauth.py) ──────────────────
# Register your app at https://developer.linkedin.com/
# Required scopes: openid, profile, w_member_social
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# LINKEDIN_TOKEN_FILE=data/tokens/linkedin.json

# ── Author profile (Streamlit LinkedIn preview only, never posted) ────────────
AUTHOR_NAME=Your Name
AUTHOR_HEADLINE=Your Headline
AUTHOR_PROFILE_PIC_URL=
